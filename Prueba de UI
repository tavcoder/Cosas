            margin-bottom: 80px;
            letter-spacing: -1px;
            animation: fadeInUp 1s ease-out;
        }

        .timeline {
            position: relative;
            max-width: 1000px;
            margin: 0 auto;
            padding: 80px 0;
        }

        .timeline-svg-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        .timeline-path {
            fill: none;
            stroke: var(--purple-primary);
            stroke-width: 4;
            stroke-linecap: round;
            opacity: 0.3;
            filter: drop-shadow(2px 2px 4px rgba(163, 177, 198, 0.2));
        }

        .timeline-items-wrapper {
            position: relative;
            z-index: 1;
        }

        .timeline-item {
            position: absolute;
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: fadeInUp 1.2s ease-out;
        }

        .timeline-item:nth-child(1) {
            top: 20px;
            left: 50px;
            animation-delay: 0s;
        }

        .timeline-item:nth-child(2) {
            top: 180px;
            right: 50px;
            animation-delay: 0.2s;
        }

        .timeline-step-badge {
            font-family: 'Fraunces', serif;
            font-size: 72px;
            font-weight: 700;
            color: var(--gray-medium);
            opacity: 0.15;
            position: absolute;
            top: -40px;
            left: -60px;
            z-index: 0;
            line-height: 1;
        }

        .timeline-node {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: var(--bg-base);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-neumorphic);
            position: relative;
            transition: all 0.4s ease;
            z-index: 2;
            margin-bottom: 16px;
        }

        .timeline-node::before {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            background: linear-gradient(135deg, 
                        rgba(99, 102, 241, 0.3) 0%, 
                        rgba(79, 70, 229, 0.3) 100%);
            z-index: -1;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .timeline-item:hover .timeline-node::before {
            opacity: 1;
        }

        .timeline-item:hover .timeline-node {
            box-shadow: 12px 12px 24px rgba(163, 177, 198, 0.5),
                        -12px -12px 24px rgba(255, 255, 255, 0.9);
            transform: translateY(-4px);
        }

        .timeline-icon-inner {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, 
                        rgba(224, 231, 255, 0.6) 0%, 
                        rgba(195, 207, 255, 0.6) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-inset);
        }

        .timeline-icon-inner svg {
            width: 24px;
            height: 24px;
            color: var(--purple-primary);
        }

        .timeline-date {
            font-family: 'Fraunces', serif;
            font-size: 16px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 20px;
            text-align: center;
            padding: 8px 20px;
            background: var(--bg-base);
            border-radius: 12px;
            box-shadow: var(--shadow-neumorphic-sm);
        }

        .timeline-content {
            background: var(--bg-base);
            border-radius: 20px;
            padding: 32px;
            box-shadow: var(--shadow-neumorphic);
            max-width: 380px;
            transition: all 0.4s ease;
            position: relative;
        }

        .timeline-item:hover .timeline-content {
            box-shadow: 12px 12px 24px rgba(163, 177, 198, 0.5), 
                        -12px -12px 24px rgba(255, 255, 255, 0.9);
        }

        .timeline-content-header {
            margin-bottom: 16px;
        }

        .timeline-content-title {
            font-family: 'Fraunces', serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 6px;
        }

        .timeline-content-subtitle {
            font-size: 14px;
            font-weight: 500;
            color: var(--gray-text);
        }

        .timeline-content-description {
            font-size: 15px;
            line-height: 1.7;
            color: var(--gray-text);
        }

        /* Decorative glow spots along the path */
        .timeline-glow {
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, 
                        rgba(99, 102, 241, 0.08) 0%, 
                        transparent 70%);
