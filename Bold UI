<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tania Arteaga - Web Developer</title>
    <meta name="description" content="Portfolio de Tania Arteaga, desarrolladora Front End que fusiona diseño neumórfico y código para crear experiencias web memorables y accesibles.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
          /* Paleta vibrante pero accesible */
          --purple-900: #312e81;      /* Texto oscuro */
          --purple-700: #5b21b6;      /* Primary dark */
          --purple-600: #7c3aed;      /* Primary */
          --purple-500: #8b5cf6;      /* Primary light */
          --purple-100: #ede9fe;      /* Backgrounds */
          --purple-50: #faf5ff;
          
          --amber-600: #d97706;       /* Accent */
          --amber-100: #fef3c7;
          
          --slate-900: #0f172a;       /* Text primary */
          --slate-700: #334155;       /* Text secondary - ACCESIBLE */
          --slate-600: #475569;
          --slate-200: #e2e8f0;       /* Borders */
          --slate-100: #f1f5f9;       /* Surface */
          
          --bg-base: #f8fafc;         /* Background principal */
          
          /* Sombras neumórficas MEJORADAS */
          --shadow-neu-raised: 
            12px 12px 24px rgba(174, 174, 192, 0.4),
            -12px -12px 24px rgba(255, 255, 255, 0.9);
          --shadow-neu-pressed:
            inset 6px 6px 12px rgba(174, 174, 192, 0.3),
            inset -6px -6px 12px rgba(255, 255, 255, 0.7);
          --shadow-neu-hover:
            16px 16px 32px rgba(174, 174, 192, 0.5),
            -16px -16px 32px rgba(255, 255, 255, 1);
          
          /* Typography */
          --font-display: 'Fraunces', serif;
          --font-body: 'DM Sans', sans-serif;
          
          /* Modular scale: 1.25 (Major Third) */
          --text-xs: 0.64rem;   /* 10px */
          --text-sm: 0.8rem;    /* 13px */
          --text-base: 1rem;    /* 16px */
          --text-lg: 1.25rem;   /* 20px */
          --text-xl: 1.563rem;  /* 25px */
          --text-2xl: 1.953rem; /* 31px */
          --text-3xl: 2.441rem; /* 39px */
          --text-4xl: 3.052rem; /* 49px */
          
          /* Spacing: 8px system */
          --space-1: 0.5rem;   /* 8px */
          --space-2: 1rem;     /* 16px */
          --space-3: 1.5rem;   /* 24px */
          --space-4: 2rem;     /* 32px */
          --space-5: 2.5rem;   /* 40px */
          --space-6: 3rem;     /* 48px */
          --space-8: 4rem;     /* 64px */
          
          /* Border radius: Fibonacci */
          --radius-sm: 8px;
          --radius-md: 13px;
          --radius-lg: 21px;
          --radius-xl: 34px;
        }

        * {
          margin: 0;
          padding: 0;
          box-sizing: border-box;
        }

        *:focus-visible {
          outline: 3px solid var(--purple-600);
          outline-offset: 2px;
        }

        body {
          font-family: var(--font-body);
          background: var(--bg-base);
          color: var(--slate-900);
          line-height: 1.6;
          min-height: 100vh;
          display: flex;
          padding: var(--space-4) var(--space-2);
          animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
          from { opacity: 0; }
          to { opacity: 1; }
        }

        /* Skip link para accesibilidad */
        .skip-link {
          position: absolute;
          top: -40px;
          left: 0;
          background: var(--purple-600);
          color: white;
          padding: var(--space-1) var(--space-2);
          text-decoration: none;
          font-weight: 600;
          z-index: 100;
          border-radius: 0 0 var(--radius-md) 0;
        }

        .skip-link:focus {
          top: 0;
        }

        .container {
          display: flex;
          max-width: 1400px;
          margin: 0 auto;
          width: 100%;
          gap: var(--space-6);
          animation: slideUp 0.9s ease-out;
        }

        @keyframes slideUp {
          from { 
            transform: translateY(30px);
            opacity: 0;
          }
          to { 
            transform: translateY(0);
            opacity: 1;
          }
        }

        /* Sidebar - 28% width */
        .sidebar {
          width: 28%;
          min-width: 280px;
          max-width: 340px;
          position: sticky;
          top: var(--space-4);
          height: fit-content;
          animation: slideInLeft 1s ease-out;
        }

        @keyframes slideInLeft {
          from { 
            transform: translateX(-50px);
            opacity: 0;
          }
          to { 
            transform: translateX(0);
            opacity: 1;
          }
        }

        .profile-card {
          background: var(--bg-base);
          border-radius: var(--radius-xl);
          padding: var(--space-6) var(--space-4);
          box-shadow: var(--shadow-neu-raised);
          display: flex;
          flex-direction: column;
          align-items: flex-start;
          position: relative;
          overflow: visible;
          transition: box-shadow 0.4s ease;
        }

        .profile-card:hover {
          box-shadow: var(--shadow-neu-hover);
        }

        .profile-avatar {
          width: 120px;
          height: 120px;
          border-radius: 50%;
          background: linear-gradient(135deg, var(--purple-600) 0%, var(--purple-700) 100%);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: var(--space-3);
          border: none;
          box-shadow: var(--shadow-neu-pressed);
          position: relative;
          overflow: hidden;
          animation: float 3s ease-in-out infinite;
          color: white;
          font-size: var(--text-4xl);
          font-weight: 700;
        }

        @keyframes float {
          0%, 100% { transform: translateY(0px); }
          50% { transform: translateY(-8px); }
        }

        .profile-avatar::after {
          content: '';
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          background: linear-gradient(135deg, rgba(255,255,255,0.3), transparent);
        }

        .profile-info {
          width: 100%;
          margin-bottom: var(--space-4);
        }

        .profile-name {
          font-family: var(--font-display);
          font-size: var(--text-2xl);
          font-weight: 700;
          color: var(--purple-700);
          margin-bottom: var(--space-1);
          letter-spacing: -0.5px;
        }

        .profile-title {
          font-size: var(--text-base);
          font-weight: 500;
          color: var(--slate-700);  /* ✅ Contraste AA */
          margin-bottom: var(--space-1);
        }

        .profile-email {
          font-size: var(--text-sm);
          color: var(--slate-700);  /* ✅ Contraste AA */
          word-break: break-all;
        }

        .profile-email a {
          color: inherit;
          text-decoration: none;
          transition: color 0.2s;
        }

        .profile-email a:hover {
          color: var(--purple-600);
        }

        .social-links {
          display: flex;
          gap: var(--space-1);
          margin-top: var(--space-2);
          width: 100%;
        }

        .social-icon {
          width: 44px;
          height: 44px;
          border-radius: var(--radius-md);
          background: var(--bg-base);
          display: flex;
          align-items: center;
          justify-content: center;
          color: var(--purple-600);  /* ✅ Más visible */
          text-decoration: none;
          transition: all 0.3s ease;
          cursor: pointer;
          box-shadow: var(--shadow-neu-raised);
        }

        .social-icon:hover {
          box-shadow: var(--shadow-neu-pressed);
          color: var(--purple-700);
          transform: scale(0.95);
        }

        .social-icon:active {
          box-shadow: inset 8px 8px 16px rgba(174, 174, 192, 0.4), 
                      inset -8px -8px 16px rgba(255, 255, 255, 0.9);
        }

        .navigation {
          width: 100%;
          display: flex;
          flex-direction: column;
          gap: var(--space-2);
          margin-bottom: var(--space-4);
        }

        .nav-list {
          list-style: none;
          display: flex;
          flex-direction: column;
          gap: var(--space-2);
        }

        .nav-link {
          display: block;
          padding: var(--space-2) var(--space-3);
          border-radius: var(--radius-md);
          border: none;
          background: var(--bg-base);
          color: var(--slate-700);  /* ✅ Contraste AA */
          font-size: var(--text-base);
          font-weight: 500;
          cursor: pointer;
          text-align: left;
          transition: all 0.3s ease;
          box-shadow: var(--shadow-neu-raised);
          font-family: var(--font-body);
          text-decoration: none;
        }

        .nav-link:hover {
          box-shadow: var(--shadow-neu-hover);
        }

        .nav-link[aria-current="page"] {
          background: linear-gradient(135deg, var(--purple-600), var(--purple-700));
          color: white;
          font-weight: 600;
          box-shadow: var(--shadow-neu-pressed),
                      0 0 20px rgba(124, 58, 237, 0.3);
        }

        /* Decorative accent */
        .accent-badge {
          display: inline-block;
          padding: var(--space-1) var(--space-2);
          background: linear-gradient(135deg, 
                      rgba(254, 243, 199, 0.8) 0%, 
                      rgba(217, 119, 6, 0.2) 100%);
          color: var(--amber-600);
          font-size: var(--text-xs);
          font-weight: 700;
          border-radius: var(--radius-sm);
          text-transform: uppercase;
          letter-spacing: 0.5px;
          box-shadow: var(--shadow-neu-pressed);
          margin-top: auto;
        }

        /* Main Content - 72% width */
        .main-content {
          flex: 1;
          display: flex;
          flex-direction: column;
          justify-content: center;
          max-width: 900px;
          animation: slideInRight 1s ease-out;
        }

        @keyframes slideInRight {
          from { 
            transform: translateX(50px);
            opacity: 0;
          }
          to { 
            transform: translateX(0);
            opacity: 1;
          }
        }

        .section {
          padding: var(--space-6) 0;
          display: none;
        }

        .section.active {
          display: block;
          animation: fadeInUp 0.6s ease-out;
        }

        @keyframes fadeInUp {
          from {
            transform: translateY(20px);
            opacity: 0;
          }
          to {
            transform: translateY(0);
            opacity: 1;
          }
        }

        .hero-title {
          margin-bottom: var(--space-3);
        }

        .title-line-1 {
          font-family: var(--font-display);
          font-size: var(--text-4xl);
          font-weight: 700;
          color: var(--purple-700);
          line-height: 1.1;
          letter-spacing: -1.5px;
          display: block;
        }

        .title-line-2 {
          font-family: var(--font-display);
          font-size: var(--text-4xl);
          font-weight: 700;
          color: var(--slate-900);  /* ✅ VISIBLE AHORA */
          line-height: 1.1;
          letter-spacing: -1.5px;
          display: block;
          background: linear-gradient(135deg, var(--slate-900), var(--purple-900));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        }

        .hero-description {
          font-size: var(--text-lg);
          line-height: 1.75;
          color: var(--slate-700);  /* ✅ Contraste AA */
          max-width: 560px;
          margin-bottom: var(--space-5);
        }

        .cta-buttons {
          display: flex;
          gap: var(--space-2);
          flex-wrap: wrap;
        }

        .btn {
          padding: var(--space-2) var(--space-4);
          border-radius: var(--radius-lg);
          font-size: var(--text-base);
          font-weight: 600;
          border: none;
          cursor: pointer;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          font-family: var(--font-body);
          text-decoration: none;
          display: inline-block;
          position: relative;
          backdrop-filter: blur(10px);
        }

        .btn-primary {
          background: linear-gradient(135deg, 
                      var(--purple-600) 0%, 
                      var(--purple-700) 100%);
          color: white;
          box-shadow: 0 8px 16px rgba(124, 58, 237, 0.3),
                      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                      0 0 20px rgba(124, 58, 237, 0.15);
          border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .btn-primary:hover {
          background: linear-gradient(135deg, 
                      var(--purple-700) 0%, 
                      var(--purple-900) 100%);
          box-shadow: 0 12px 24px rgba(124, 58, 237, 0.4),
                      0 0 30px rgba(124, 58, 237, 0.3),
                      0 0 0 1px rgba(255, 255, 255, 0.2) inset,
                      0 0 40px rgba(124, 58, 237, 0.15);
          transform: translateY(-2px);
          border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .btn-primary:active {
          transform: translateY(0);
          box-shadow: 0 4px 8px rgba(124, 58, 237, 0.3),
                      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                      0 0 12px rgba(124, 58, 237, 0.2);
        }

        .btn-secondary {
          background: var(--bg-base);
          color: var(--slate-900);
          box-shadow: var(--shadow-neu-raised);
        }

        .btn-secondary:hover {
          box-shadow: var(--shadow-neu-hover);
          transform: translateY(-2px);
        }

        .btn-secondary:active {
          transform: translateY(0);
          box-shadow: var(--shadow-neu-pressed);
        }

        /* About Section */
        .section-title {
          font-family: var(--font-display);
          font-size: var(--text-3xl);
          font-weight: 700;
          color: var(--purple-700);
          margin-bottom: var(--space-4);
          letter-spacing: -1px;
        }

        .about-text {
          font-size: var(--text-lg);
          line-height: 1.8;
          color: var(--slate-700);
          max-width: 720px;
          margin-bottom: var(--space-6);
        }

        .skills-group {
          margin-bottom: var(--space-5);
        }

        .skills-group-title {
          font-family: var(--font-display);
          font-size: var(--text-xl);
          font-weight: 600;
          color: var(--purple-700);
          margin-bottom: var(--space-3);
          letter-spacing: -0.3px;
        }

        .skills-list {
          display: flex;
          flex-wrap: wrap;
          gap: var(--space-2);
          margin-bottom: var(--space-2);
        }

        .skill-tag {
          padding: var(--space-1) var(--space-3);
          border-radius: var(--radius-md);
          background: var(--bg-base);
          color: var(--slate-700);
          font-size: var(--text-base);
          font-weight: 500;
          display: flex;
          align-items: center;
          gap: var(--space-1);
          box-shadow: var(--shadow-neu-raised);
          transition: all 0.3s ease;
          position: relative;
        }

        .skill-tag::before {
          content: '✓';
          color: var(--purple-600);
          font-weight: 700;
          font-size: var(--text-sm);
        }

        .skill-tag:hover {
          box-shadow: var(--shadow-neu-hover);
          transform: translateY(-2px);
        }

        /* Projects Section */
        .projects-grid {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
          gap: var(--space-4);
          max-width: 1100px;
        }

        .project-card {
          background: var(--bg-base);
          border-radius: var(--radius-xl);
          padding: var(--space-3);
          box-shadow: var(--shadow-neu-raised);
          transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
          position: relative;
          overflow: hidden;
        }

        .project-card:hover {
          box-shadow: var(--shadow-neu-hover);
          transform: translateY(-4px);
        }

        .project-image-container {
          width: 100%;
          height: 240px;
          border-radius: var(--radius-lg);
          overflow: hidden;
          margin-bottom: var(--space-3);
          position: relative;
          background: var(--slate-100);
          box-shadow: var(--shadow-neu-pressed);
        }

        .project-image {
          width: 100%;
          height: 100%;
          object-fit: cover;
          transition: transform 0.4s ease, opacity 0.4s ease;
        }

        .project-card:hover .project-image {
          transform: scale(1.05);
          opacity: 0.8;
        }

        .project-title {
          font-family: var(--font-display);
          font-size: var(--text-xl);
          font-weight: 600;
          color: var(--purple-700);
          margin-bottom: var(--space-2);
        }

        .project-description {
          font-size: var(--text-base);
          line-height: 1.6;
          color: var(--slate-700);
          margin-bottom: var(--space-3);
        }

        .project-tech-stack {
          display: flex;
          gap: var(--space-2);
          flex-wrap: wrap;
          margin-bottom: var(--space-3);
        }

        .tech-icon {
          width: 40px;
          height: 40px;
          border-radius: var(--radius-sm);
          background: var(--bg-base);
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: var(--shadow-neu-raised);
          transition: all 0.3s ease;
          font-size: var(--text-lg);
        }

        .tech-icon:hover {
          box-shadow: var(--shadow-neu-hover);
          transform: translateY(-2px);
        }

        .project-links {
          display: flex;
          gap: var(--space-2);
        }

        .project-btn {
          padding: var(--space-1) var(--space-3);
          border-radius: var(--radius-md);
          font-size: var(--text-sm);
          font-weight: 600;
          border: none;
          cursor: pointer;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          font-family: var(--font-body);
          position: relative;
          backdrop-filter: blur(10px);
          display: flex;
          align-items: center;
          gap: var(--space-1);
          text-decoration: none;
        }

        .project-btn-primary {
          background: linear-gradient(135deg, 
                      var(--purple-600) 0%, 
                      var(--purple-700) 100%);
          color: white;
          box-shadow: 0 4px 8px rgba(124, 58, 237, 0.25),
                      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                      0 0 16px rgba(124, 58, 237, 0.12);
          border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .project-btn-primary:hover {
          background: linear-gradient(135deg, 
                      var(--purple-700) 0%, 
                      var(--purple-900) 100%);
          box-shadow: 0 6px 12px rgba(124, 58, 237, 0.35),
                      0 0 0 1px rgba(255, 255, 255, 0.2) inset,
                      0 0 20px rgba(124, 58, 237, 0.25);
          transform: translateY(-1px);
        }

        .project-btn-secondary {
          background: var(--bg-base);
          color: var(--slate-900);
          box-shadow: var(--shadow-neu-raised);
        }

        .project-btn-secondary:hover {
          box-shadow: var(--shadow-neu-hover);
          transform: translateY(-1px);
        }

        /* Education/Timeline Section */
        .timeline {
          position: relative;
          max-width: 1000px;
          margin: 0 auto;
          padding: var(--space-4) 0;
        }

        .timeline-item {
          position: relative;
          padding-left: var(--space-6);
          padding-bottom: var(--space-6);
          display: flex;
          flex-direction: column;
        }

        .timeline-item::before {
          content: '';
          position: absolute;
          left: 14px;
          top: 36px;
          bottom: 0;
          width: 3px;
          background: linear-gradient(180deg, 
                      var(--purple-600) 0%, 
                      var(--purple-600) 50%,
                      transparent 100%);
          opacity: 0.3;
          border-radius: var(--radius-sm);
        }

        .timeline-item:last-child::before {
          display: none;
        }

        .timeline-node {
          position: absolute;
          left: 0;
          top: 0;
          width: 32px;
          height: 32px;
          border-radius: 50%;
          background: var(--bg-base);
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: var(--shadow-neu-raised);
          position: relative;
          transition: all 0.4s ease;
          z-index: 2;
        }

        .timeline-node::before {
          content: '';
          position: absolute;
          inset: -3px;
          border-radius: 50%;
          background: linear-gradient(135deg, 
                      var(--purple-600) 0%, 
                      var(--purple-700) 100%);
          z-index: -1;
          opacity: 0;
          transition: opacity 0.4s ease;
        }

        .timeline-item:hover .timeline-node::before {
          opacity: 1;
        }

        .timeline-item:hover .timeline-node {
          box-shadow: var(--shadow-neu-hover);
          transform: scale(1.1);
        }

        .timeline-icon-inner {
          width: 20px;
          height: 20px;
          border-radius: 50%;
          background: linear-gradient(135deg, 
                      var(--purple-600) 0%, 
                      var(--purple-700) 100%);
          display: flex;
          align-items: center;
          justify-content: center;
          color: white;
        }

        .timeline-date {
          font-family: var(--font-display);
          font-size: var(--text-base);
          font-weight: 600;
          color: var(--purple-600);
          margin-bottom: var(--space-2);
        }

        .timeline-content {
          background: var(--bg-base);
          border-radius: var(--radius-lg);
          padding: var(--space-4);
          box-shadow: var(--shadow-neu-raised);
          transition: all 0.4s ease;
          position: relative;
        }

        .timeline-item:hover .timeline-content {
          box-shadow: var(--shadow-neu-hover);
        }

        .timeline-content-header {
          margin-bottom: var(--space-2);
        }

        .timeline-content-title {
          font-family: var(--font-display);
          font-size: var(--text-xl);
          font-weight: 600;
          color: var(--purple-700);
          margin-bottom: var(--space-1);
        }

        .timeline-content-subtitle {
          font-size: var(--text-base);
          font-weight: 500;
          color: var(--slate-700);
        }

        .timeline-content-description {
          font-size: var(--text-base);
          line-height: 1.7;
          color: var(--slate-700);
        }

        /* Decorative elements */
        .floating-decoration {
          position: fixed;
          pointer-events: none;
          opacity: 0.1;
          z-index: 0;
        }

        .decoration-1 {
          top: 10%;
          right: 10%;
          width: 200px;
          height: 200px;
          background: radial-gradient(circle, var(--purple-600), transparent);
          border-radius: 50%;
          animation: float 6s ease-in-out infinite;
          box-shadow: 0 0 40px rgba(124, 58, 237, 0.2);
        }

        .decoration-2 {
          bottom: 15%;
          left: 5%;
