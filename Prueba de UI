<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tania Arteaga - Web Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --purple-primary: #6366f1;
            --purple-dark: #4f46e5;
            --purple-light: #e0e7ff;
            --purple-bg: #f5f7ff;
            --yellow-accent: #fef3c7;
            --yellow-dark: #fbbf24;
            --gray-text: #64748b;
            --gray-light: #f1f5f9;
            --gray-medium: #cbd5e1;
            --bg-base: #e8ecf5;
            --shadow-neumorphic: 8px 8px 16px rgba(163, 177, 198, 0.6), 
                                 -8px -8px 16px rgba(255, 255, 255, 0.9);
            --shadow-neumorphic-sm: 4px 4px 8px rgba(163, 177, 198, 0.4), 
                                     -4px -4px 8px rgba(255, 255, 255, 0.8);
            --shadow-inset: inset 4px 4px 8px rgba(163, 177, 198, 0.3), 
                            inset -4px -4px 8px rgba(255, 255, 255, 0.7);
            --shadow-inset-deep: inset 6px 6px 12px rgba(163, 177, 198, 0.4), 
                                 inset -6px -6px 12px rgba(255, 255, 255, 0.8);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-base);
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            padding: 40px 20px;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .container {
            display: flex;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 60px;
            animation: slideUp 0.9s ease-out;
        }

        @keyframes slideUp {
            from { 
                transform: translateY(30px);
                opacity: 0;
            }
            to { 
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Sidebar - 28% width */
        .sidebar {
            width: 28%;
            min-width: 280px;
            max-width: 340px;
            position: sticky;
            top: 40px;
            height: fit-content;
            animation: slideInLeft 1s ease-out;
        }

        @keyframes slideInLeft {
            from { 
                transform: translateX(-50px);
                opacity: 0;
            }
            to { 
                transform: translateX(0);
                opacity: 1;
            }
        }

        .profile-card {
            background: var(--bg-base);
            border-radius: 32px;
            padding: 48px 32px;
            box-shadow: var(--shadow-neumorphic);
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            position: relative;
            overflow: visible;
            transition: box-shadow 0.4s ease;
        }

        .profile-card:hover {
            box-shadow: 12px 12px 24px rgba(163, 177, 198, 0.5), 
                        -12px -12px 24px rgba(255, 255, 255, 0.9);
        }

        .profile-card::before {
            display: none;
        }

        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e8ecf5 0%, #d8dce8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            border: none;
            box-shadow: var(--shadow-inset-deep);
            position: relative;
            overflow: hidden;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-8px); }
        }

        .profile-avatar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120"><circle cx="60" cy="45" r="20" fill="%236366f1" opacity="0.3"/><circle cx="60" cy="85" r="30" fill="%236366f1" opacity="0.3"/></svg>') center/cover;
        }

        .profile-info {
            width: 100%;
            margin-bottom: 32px;
        }

        .profile-name {
            font-family: 'Fraunces', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--purple-primary);
            margin-bottom: 6px;
            letter-spacing: -0.5px;
        }

        .profile-title {
            font-size: 15px;
            font-weight: 500;
            color: var(--gray-text);
            margin-bottom: 8px;
        }

        .profile-email {
            font-size: 13px;
            color: var(--gray-medium);
            word-break: break-all;
        }

        .social-links {
            display: flex;
            gap: 12px;
            margin-top: 16px;
            width: 100%;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--bg-base);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-text);
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: var(--shadow-neumorphic-sm);
        }

        .social-icon:hover {
            background: var(--bg-base);
            color: var(--purple-primary);
            box-shadow: var(--shadow-inset);
            transform: translateY(0);
        }

        .social-icon:active {
            box-shadow: var(--shadow-inset-deep);
        }

        .navigation {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 32px;
        }

        .nav-button {
            padding: 16px 24px;
            border-radius: 16px;
            border: none;
            background: var(--bg-base);
            color: var(--gray-text);
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            text-align: left;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-neumorphic-sm);
            font-family: 'DM Sans', sans-serif;
        }

        .nav-button:hover {
            box-shadow: 6px 6px 12px rgba(163, 177, 198, 0.5), 
                        -6px -6px 12px rgba(255, 255, 255, 0.9);
            transform: translateX(0);
        }

        .nav-button.active {
            background: var(--bg-base);
            color: var(--purple-primary);
            font-weight: 600;
            box-shadow: var(--shadow-inset);
        }

        .language-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--gray-text);
            margin-top: auto;
        }

        .toggle-switch {
            width: 48px;
            height: 24px;
            background: var(--bg-base);
            border-radius: 12px;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-inset);
        }

        .toggle-switch.active {
            background: var(--bg-base);
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            background: linear-gradient(135deg, #f0f4fb 0%, #e0e4f0 100%);
            border-radius: 50%;
            transition: transform 0.3s ease;
            box-shadow: 3px 3px 6px rgba(163, 177, 198, 0.4), 
                        -2px -2px 4px rgba(255, 255, 255, 0.8);
        }

        .toggle-switch.active::after {
            transform: translateX(24px);
            background: linear-gradient(135deg, var(--purple-light) 0%, #c7cbf5 100%);
        }

        /* Main Content - 72% width */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            max-width: 900px;
            animation: slideInRight 1s ease-out;
        }

        @keyframes slideInRight {
            from { 
                transform: translateX(50px);
                opacity: 0;
            }
            to { 
                transform: translateX(0);
                opacity: 1;
            }
        }

        .hero {
            padding: 60px 0;
            display: block;
        }

        .hero.hidden {
            display: none;
        }

        .hero-title {
            margin-bottom: 24px;
            animation: fadeInUp 1.2s ease-out 0.2s both;
        }

        @keyframes fadeInUp {
            from {
                transform: translateY(20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .title-line-1 {
            font-family: 'Fraunces', serif;
            font-size: 56px;
            font-weight: 700;
            color: var(--purple-primary);
            line-height: 1.1;
            letter-spacing: -1.5px;
            display: block;
        }

        .title-line-2 {
            font-family: 'Fraunces', serif;
            font-size: 56px;
            font-weight: 700;
            color: #f8faff;
            line-height: 1.1;
            letter-spacing: -1.5px;
            display: block;
            text-shadow: 2px 2px 4px rgba(163, 177, 198, 0.3),
                         -1px -1px 2px rgba(255, 255, 255, 0.5);
        }

        .hero-description {
            font-size: 18px;
            line-height: 1.75;
            color: var(--gray-text);
            max-width: 560px;
            margin-bottom: 40px;
            animation: fadeInUp 1.2s ease-out 0.4s both;
        }

        .cta-buttons {
            display: flex;
            gap: 16px;
            animation: fadeInUp 1.2s ease-out 0.6s both;
        }

        .btn {
            padding: 18px 36px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            display: inline-block;
            position: relative;
            backdrop-filter: blur(10px);
        }

        .btn-primary {
            background: linear-gradient(135deg, 
                        rgba(124, 127, 245, 0.95) 0%, 
                        rgba(99, 102, 241, 0.95) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25),
                        0 2px 4px rgba(99, 102, 241, 0.2),
                        0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                        0 0 20px rgba(99, 102, 241, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, 
                        rgba(132, 135, 247, 0.98) 0%, 
                        rgba(113, 116, 243, 0.98) 100%);
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35),
                        0 3px 6px rgba(99, 102, 241, 0.25),
                        0 0 0 1px rgba(255, 255, 255, 0.2) inset,
                        0 0 28px rgba(99, 102, 241, 0.3),
                        0 0 40px rgba(99, 102, 241, 0.15);
            transform: translateY(-1px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .btn-primary:active {
            transform: translateY(0);
            box-shadow: 0 2px 6px rgba(99, 102, 241, 0.3),
                        0 1px 2px rgba(99, 102, 241, 0.2),
                        0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                        0 0 12px rgba(99, 102, 241, 0.2);
        }

        .btn-secondary {
            background: linear-gradient(135deg, 
                        rgba(254, 248, 224, 0.95) 0%, 
                        rgba(254, 243, 199, 0.95) 100%);
            color: var(--purple-dark);
            box-shadow: 0 4px 12px rgba(251, 191, 36, 0.2),
                        0 2px 4px rgba(251, 191, 36, 0.15),
                        0 0 0 1px rgba(255, 255, 255, 0.3) inset,
                        0 0 20px rgba(251, 191, 36, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }

        .btn-secondary:hover {
            background: linear-gradient(135deg, 
                        rgba(255, 250, 235, 0.98) 0%, 
                        rgba(254, 246, 214, 0.98) 100%);
            box-shadow: 0 6px 16px rgba(251, 191, 36, 0.28),
                        0 3px 6px rgba(251, 191, 36, 0.2),
                        0 0 0 1px rgba(255, 255, 255, 0.4) inset,
                        0 0 28px rgba(251, 191, 36, 0.2),
                        0 0 40px rgba(251, 191, 36, 0.12);
            transform: translateY(-1px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .btn-secondary:active {
            transform: translateY(0);
            box-shadow: 0 2px 6px rgba(251, 191, 36, 0.2),
                        0 1px 2px rgba(251, 191, 36, 0.15),
                        0 0 0 1px rgba(255, 255, 255, 0.3) inset,
                        0 0 12px rgba(251, 191, 36, 0.15);
        }

        /* Decorative elements */
        .floating-decoration {
            position: fixed;
            pointer-events: none;
            opacity: 0.08;
            z-index: 0;
        }

        .decoration-1 {
            top: 10%;
            right: 10%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.3), transparent);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
            box-shadow: 0 0 40px rgba(99, 102, 241, 0.1);
        }

        .decoration-2 {
            bottom: 15%;
            left: 5%;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, rgba(251, 191, 36, 0.3), transparent);
            border-radius: 50%;
            animation: float 8s ease-in-out infinite reverse;
            box-shadow: 0 0 40px rgba(251, 191, 36, 0.1);
        }

        /* About Section */
        .about-section {
            padding: 60px 0;
            display: none;
        }

        .about-section.active {
            display: block;
        }

        .about-title {
            font-family: 'Fraunces', serif;
            font-size: 42px;
            font-weight: 700;
            color: var(--purple-primary);
            margin-bottom: 32px;
            letter-spacing: -1px;
            animation: fadeInUp 1s ease-out;
        }

        .about-text {
            font-size: 17px;
            line-height: 1.8;
            color: var(--gray-text);
            max-width: 720px;
            margin-bottom: 48px;
            animation: fadeInUp 1.1s ease-out;
        }

        .skills-group {
            margin-bottom: 40px;
            animation: fadeInUp 1.2s ease-out;
        }

        .skills-group-title {
            font-family: 'Fraunces', serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 20px;
            letter-spacing: -0.3px;
        }

        .skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 16px;
        }

        .skill-tag {
            padding: 12px 24px;
            border-radius: 12px;
            background: var(--bg-base);
            color: var(--gray-text);
            font-size: 15px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: var(--shadow-neumorphic-sm);
            transition: all 0.3s ease;
            position: relative;
        }

        .skill-tag::before {
            content: '✓';
            color: var(--purple-primary);
            font-weight: 700;
            font-size: 14px;
        }

        .skill-tag:hover {
            box-shadow: 6px 6px 12px rgba(163, 177, 198, 0.4), 
                        -6px -6px 12px rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

        .languages-card {
            display: inline-block;
            padding: 20px 32px;
            border-radius: 16px;
            background: linear-gradient(135deg, 
                        rgba(224, 231, 255, 0.4) 0%, 
                        rgba(195, 207, 255, 0.4) 100%);
            box-shadow: var(--shadow-neumorphic-sm);
            animation: fadeInUp 1.3s ease-out;
            position: relative;
            overflow: hidden;
        }

        .languages-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.15), transparent);
            border-radius: 50%;
        }

        .languages-title {
            font-family: 'DM Sans', sans-serif;
            font-size: 16px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
        }

        .language-tag {
            display: inline-block;
            padding: 8px 18px;
            margin: 4px 8px 4px 0;
            border-radius: 10px;
            background: var(--bg-base);
            color: var(--gray-text);
            font-size: 14px;
            font-weight: 500;
            box-shadow: var(--shadow-inset);
            position: relative;
            z-index: 1;
        }

        /* Projects Section */
        .projects-section {
            padding: 60px 0;
            display: none;
        }

        .projects-section.active {
            display: block;
        }

        .projects-title {
            font-family: 'Fraunces', serif;
            font-size: 42px;
            font-weight: 700;
            color: var(--purple-primary);
            margin-bottom: 48px;
            letter-spacing: -1px;
            animation: fadeInUp 1s ease-out;
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 32px;
            max-width: 1100px;
        }

        .project-card {
            background: var(--bg-base);
            border-radius: 24px;
            padding: 24px;
            box-shadow: var(--shadow-neumorphic);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            animation: fadeInUp 1.1s ease-out;
        }

        .project-card:hover {
            box-shadow: 12px 12px 24px rgba(163, 177, 198, 0.5), 
                        -12px -12px 24px rgba(255, 255, 255, 0.9);
        }

        .project-image-container {
            width: 100%;
            height: 240px;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 20px;
            position: relative;
            background: var(--bg-base);
            box-shadow: var(--shadow-inset);
        }

        .project-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.4s ease;
        }

        .project-hover-content {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, 
                        rgba(232, 236, 245, 0.98) 0%, 
                        rgba(220, 226, 240, 0.98) 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 24px;
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }

        .project-card:hover .project-hover-content {
            opacity: 1;
            pointer-events: all;
        }

        .project-card:hover .project-image {
            opacity: 0;
        }

        .project-hover-title {
            font-family: 'Fraunces', serif;
            font-size: 18px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 12px;
            text-align: center;
        }

        .project-hover-description {
            font-size: 14px;
            line-height: 1.6;
            color: var(--gray-text);
            text-align: center;
            margin-bottom: 20px;
        }

        .project-title {
            font-family: 'Fraunces', serif;
            font-size: 18px;
            font-weight: 600;
            color: var(--purple-primary);
            margin-bottom: 12px;
        }

        .project-tech-stack {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .tech-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: var(--bg-base);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-neumorphic-sm);
            transition: all 0.3s ease;
            font-size: 18px;
        }

        .tech-icon:hover {
            box-shadow: 6px 6px 12px rgba(163, 177, 198, 0.4), 
                        -6px -6px 12px rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

        .project-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .project-btn {
            padding: 10px 20px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: 'DM Sans', sans-serif;
            position: relative;
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .project-btn-primary {
            background: linear-gradient(135deg, 
                        rgba(124, 127, 245, 0.95) 0%, 
                        rgba(99, 102, 241, 0.95) 100%);
            color: white;
            box-shadow: 0 3px 8px rgba(99, 102, 241, 0.25),
                        0 1px 3px rgba(99, 102, 241, 0.2),
                        0 0 0 1px rgba(255, 255, 255, 0.1) inset,
                        0 0 16px rgba(99, 102, 241, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .project-btn-primary:hover {
            background: linear-gradient(135deg, 
                        rgba(132, 135, 247, 0.98) 0%, 
                        rgba(113, 116, 243, 0.98) 100%);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35),
                        0 2px 4px rgba(99, 102, 241, 0.25),
                        0 0 0 1px rgba(255, 255, 255, 0.2) inset,
                        0 0 20px rgba(99, 102, 241, 0.25);
            transform: translateY(-1px);
        }

        .project-btn-secondary {
            background: linear-gradient(135deg, 
                        rgba(254, 248, 224, 0.95) 0%, 
                        rgba(254, 243, 199, 0.95) 100%);
            color: var(--purple-dark);
            box-shadow: 0 3px 8px rgba(251, 191, 36, 0.2),
                        0 1px 3px rgba(251, 191, 36, 0.15),
                        0 0 0 1px rgba(255, 255, 255, 0.3) inset,
                        0 0 16px rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }

        .project-btn-secondary:hover {
            background: linear-gradient(135deg, 
                        rgba(255, 250, 235, 0.98) 0%, 
                        rgba(254, 246, 214, 0.98) 100%);
            box-shadow: 0 4px 12px rgba(251, 191, 36, 0.28),
                        0 2px 4px rgba(251, 191, 36, 0.2),
                        0 0 0 1px rgba(255, 255, 255, 0.4) inset,
                        0 0 20px rgba(251, 191, 36, 0.18);
            transform: translateY(-1px);
        }

        .project-btn-more {
            background: var(--bg-base);
            color: var(--gray-text);
            box-shadow: var(--shadow-neumorphic-sm);
            border: 1px solid transparent;
            width: 40px;
            height: 40px;
            padding: 0;
            justify-content: center;
        }

        .project-btn-more:hover {
            box-shadow: 6px 6px 12px rgba(163, 177, 198, 0.4), 
                        -6px -6px 12px rgba(255, 255, 255, 0.9);
            transform: translateY(-1px);
        }

        /* Education/Studies Section */
        .education-section {
            padding: 60px 0;
            display: none;
        }

